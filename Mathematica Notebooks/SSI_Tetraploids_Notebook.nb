Cell["\<\
Comment : a crash or up for very specific values close to the edge\
\>", "Text",
 CellChangeTimes->{{3.980916028157299*^9, 
  3.9809160347018642`*^9}},ExpressionUUID->"55fe40d5-bf4f-3648-9988-\
f8c947b5b153"],

Cell["\<\
All coefficient can be negative, and the equilibrium is stable when they are \
> 0. We find therefore the limite when they are = 0 to determine the \
inbreeding depression threshold to prevent the invasion of an SC allele .
   As all of them need to be positive for the equilibrium to be stable, the \
ID threshold will be the maximum \[Delta] found .\
\>", "Text",
 CellChangeTimes->{{3.980912845821207*^9, 
  3.9809128509641476`*^9}},ExpressionUUID->"bf54efef-738e-4d41-bce0-\
bb0eb1fa6b06"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"detFrac", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"Together", "[", "c1", "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.980916403494009*^9, 3.9809164212428627`*^9}, {
   3.980916455259775*^9, 3.9809165249326096`*^9}, 3.980929868994938*^9, {
   3.9809340910561275`*^9, 3.9809340913069572`*^9}},
 CellLabel->
  "In[1051]:=",ExpressionUUID->"4d0e3d60-5090-2247-aa5f-390461b1c97c"],

