 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"4", " ", "n", " ", 
     RowBox[{"(", 
      RowBox[{"2048", "+", 
       RowBox[{"n", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "768"}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"128", "-", 
             RowBox[{"7", " ", "n"}]}], ")"}], " ", "n"}]}], ")"}]}]}], 
      ")"}]}], "+", 
    RowBox[{"11", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "8"}], "+", "n"}], ")"}], " ", "n", " ", 
     RowBox[{"(", 
      RowBox[{"32", "+", 
       RowBox[{
