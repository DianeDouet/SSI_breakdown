Cell[BoxData[
 RowBox[{
  RowBox[{"n", ">", 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{"2", "+", 
      SqrtBox["2"]}], ")"}]}]}], "&&", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"-", "4"}], "+", 
     RowBox[{"4", " ", "n"}]}], 
