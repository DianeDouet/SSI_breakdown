  RowBox[{"c3", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Coefficient", "[", 
      RowBox[{"Pr", ",", " ", "r", ",", "0"}], "]"}], "/", "c0"}], "]"}]}], 
  ";"}]}], "Input",
