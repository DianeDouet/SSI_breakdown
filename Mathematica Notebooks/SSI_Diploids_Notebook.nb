Cell[CellGroupData[{

Cell["Routh - Hurwitz conditions for stability", "Subsubsection",
 CellChangeTimes->{{3.9781467854267406`*^9, 
  3.978146788754101*^9}},ExpressionUUID->"ea39f79a-da75-8145-9b91-\
8123a847fa7c"],

Cell["On calcule le polyn\[OHat]me caract\[EAcute]ristique de la matrice matD \
:", "Text",
 CellChangeTimes->{{3.9781467950043125`*^9, 
  3.9781467996872826`*^9}},ExpressionUUID->"51ad1fad-6854-d244-bf02-\
890508595496"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"P", " ", "=", " ", 
  RowBox[{"CharacteristicPolynomial", "[", 
   RowBox[{"matD", ",", " ", "\[Lambda]"}], "]"}]}]], "Input",
 CellLabel->
  "In[516]:=",ExpressionUUID->"392b8e55-99ff-0f49-8195-fcc3376ee7af"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", "2"]}], " ", "s", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"s", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "3"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"4", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", "s"}], ")"}]}], "+", 
          RowBox[{"n", " ", 
           RowBox[{"(", 
            RowBox[{"4", "-", 
             RowBox[{"4", " ", "s"}], "+", 
             RowBox[{"n", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "2"}], "+", "s", "+", 
                RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]}], ")"}]}]}], 
         ")"}]}], 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{"s", " ", "\[Delta]"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "4"}], "+", 
          RowBox[{"4", " ", "s", " ", "\[Delta]"}]}], ")"}]}]]}], "-", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"4", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "s"}], ")"}]}], "+", 
         RowBox[{"n", " ", 
          RowBox[{"(", 
           RowBox[{"4", "-", 
            RowBox[{"4", " ", "s"}], "+", 
            RowBox[{"n", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "2"}], "+", "s", "+", 
               RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]}], ")"}]}]}], ")"}], 
       " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          FractionBox[
           RowBox[{"s", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "2"]}], 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"s", " ", "\[Delta]"}]}]]}], "-", "\[Lambda]"}], ")"}]}], 
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]]}], ")"}]}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"s", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"4", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "s"}], ")"}]}], "+", 
         RowBox[{"n", " ", 
          RowBox[{"(", 
           RowBox[{"4", "-", 
            RowBox[{"4", " ", "s"}], "+", 
            RowBox[{"n", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "2"}], "+", "s", "+", 
               RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]}], ")"}]}]}], 
        ")"}]}], 
      RowBox[{"4", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{"2", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "2"}], "+", "n"}], ")"}], " ", "n"}]}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"]], "-", 
        FractionBox["s", "2"], "-", "\[Lambda]"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"s", " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "2"]}], 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"s", " ", "\[Delta]"}]}]]}], "-", "\[Lambda]"}], ")"}]}]}],
     ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"s", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "2"]}], 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{"2", " ", "s", " ", "\[Delta]"}]}]]}], "-", "\[Lambda]"}], 
    ")"}]}]}]], "Output",
