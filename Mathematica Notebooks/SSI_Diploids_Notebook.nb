       RowBox[{"r", "^", "2"}]}], "]"}], "/", "c0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c2", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Coefficient", "[", 
      RowBox[{"Pr", ",", "r"}], "]"}], "/", "c0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
