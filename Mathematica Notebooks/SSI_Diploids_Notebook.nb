Cell["\<\
On subsitute 1 + r \[AGrave] \[Lambda] pour obtenir ensuite les conditions RH \
en discret :\
\>", "Text",
 CellChangeTimes->{{3.978146805635103*^9, 
  3.978146808867882*^9}},ExpressionUUID->"157a3585-89ef-e24b-b1bc-\
52eecca5daf0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Pr", " ", "=", " ", 
  RowBox[{
   RowBox[{"-", "P"}], "/.", 
   RowBox[{"\[Lambda]", "->", 
    RowBox[{"1", "+", "r"}]}]}]}]], "Input",
 CellLabel->
  "In[517]:=",ExpressionUUID->"4f9cb4cb-fc1f-e543-b926-8113f1c5167a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", "r", "-", 
       FractionBox[
        RowBox[{"s", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "2"]}], 
        RowBox[{
         RowBox[{"-", "2"}], "+", 
         RowBox[{"2", " ", "s", " ", "\[Delta]"}]}]]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          FractionBox[
           RowBox[{"2", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "2"}], "+", "n"}], ")"}], " ", "n"}]}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"]], "-", "r", "-", 
          FractionBox["s", "2"]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "-", "r", "-", 
          FractionBox[
           RowBox[{"s", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "2"]}], 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"s", " ", "\[Delta]"}]}]]}], ")"}]}], "+", 
       FractionBox[
        RowBox[{"s", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"4", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "s"}], ")"}]}], "+", 
           RowBox[{"n", " ", 
            RowBox[{"(", 
             RowBox[{"4", "-", 
              RowBox[{"4", " ", "s"}], "+", 
              RowBox[{"n", " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"-", "2"}], "+", "s", "+", 
                 RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]}], ")"}]}]}], 
          ")"}]}], 
        RowBox[{"4", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]]}], ")"}]}], ")"}]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", "s", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"s", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "3"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"4", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", "s"}], ")"}]}], "+", 
          RowBox[{"n", " ", 
           RowBox[{"(", 
            RowBox[{"4", "-", 
             RowBox[{"4", " ", "s"}], "+", 
             RowBox[{"n", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "2"}], "+", "s", "+", 
                RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]}], ")"}]}]}], 
         ")"}]}], 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{"s", " ", "\[Delta]"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "4"}], "+", 
          RowBox[{"4", " ", "s", " ", "\[Delta]"}]}], ")"}]}]]}], "-", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "-", "r", "-", 
         FractionBox[
          RowBox[{"s", " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "\[Delta]"}], ")"}], "2"]}], 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"s", " ", "\[Delta]"}]}]]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"4", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", "s"}], ")"}]}], "+", 
         RowBox[{"n", " ", 
          RowBox[{"(", 
           RowBox[{"4", "-", 
            RowBox[{"4", " ", "s"}], "+", 
            RowBox[{"n", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "2"}], "+", "s", "+", 
               RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]}], ")"}]}]}], 
        ")"}]}], 
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.9794475774755077`*^9, 3.9794484612062073`*^9, 
