                RowBox[{"-", "2"}], "+", "s", "+", 
                RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]}], ")"}]}]}], 
         ")"}]}], 
       RowBox[{"2", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "2"}], "+", "n"}], ")"}], "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{"s", " ", "\[Delta]"}]}], ")"}]}]]}], ",", 
     RowBox[{
      FractionBox[
       RowBox[{"2", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "2"}], "+", "n"}], ")"}], " ", "n"}]}], 
